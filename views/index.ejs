<body>

<h1>Course Management System</h1>

<a href="/add">Add Course</a>

<br><br>

<form action="/search">

<input
type="text"
name="search"
placeholder="Search Course">

<button>Search</button>

</form>

<br>

<table border="1">

<tr>
<th>Course</th>
<th>Trainer</th>
<th>Duration</th>
<th>Fees</th>
<th>Mode</th>
<th>Action</th>
</tr>

<% courses.forEach(course=>{ %>

<tr>

<td><%= course.courseName %></td>

<td><%= course.trainerName %></td>

<td><%= course.duration %></td>

<td><%= course.fees %></td>

<td><%= course.mode %></td>

<td>

<a href="/edit/<%= course._id %>">Edit</a>

|

<a href="/delete/<%= course._id %>">Delete</a>
</td>

</tr>

<% }) %>

</table>

</body>
</html>






